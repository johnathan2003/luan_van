# ============================================================
# DATABASE (PostgreSQL / Supabase)
DATABASE_URL=postgresql://shopvn_user:shopvn_pass@localhost:5432/ecommerce_db
DIRECT_URL=postgresql://shopvn_user:shopvn_pass@localhost:5432/ecommerce_db
# ============================================================
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.[project-ref]
DB_PASSWORD=your-db-password
DB_NAME=postgres

# Supabase Storage + Auth
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_STORAGE_BUCKET=uploads

# ============================================================
# JWT
# ============================================================
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# PAYMENT GATEWAYS
# ============================================================
MOMO_ENDPOINT=https://test-payment.momo.vn/v3/gateway/api/create
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-frontend.vercel.app/payment/vnpay-return

# ============================================================
# SERVER
# ============================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False
ENVIRONMENT=production
FRONTEND_URL=https://your-frontend.vercel.app
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ============================================================
# EMAIL
# ============================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=noreply@yourdomain.com

# ============================================================
# FILE UPLOAD
# ============================================================
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE=10485760

# ============================================================
# REDIS (Upstash hoặc Render Redis)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
