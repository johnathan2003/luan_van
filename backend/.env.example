# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1
DB_NAME=ecommerce_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Momo Payment
MOMO_ENDPOINT=https://test-payment.momo.vn/v3/gateway/api/create
MOMO_PARTNER_CODE=MOMOXXXXXX
MOMO_ACCESS_KEY=F8BFxxxxxxxx
MOMO_SECRET_KEY=K9xxxxxxxxxxxxx

# VNPay
VNPAY_TMN_CODE=XXXXXXXX
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=noreply@ecommerce.com

# File Upload
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE=10485760

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
